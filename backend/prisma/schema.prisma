generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  PENDING
  COMPLETED
  NOT_DONE
  DELAYED
}

enum BillingApprovalStatus {
  NOT_REQUIRED
  PENDING_EMPLOYEE_CONFIRMATION
  APPROVED_FOR_BILLING
  REJECTED_FOR_BILLING
}

enum BillStatus {
  DRAFT
  GENERATED
  EMAILED
  CANCELLED
}

enum BillSourceType {
  TASK_BASED
  MANUAL
  CLUBBED
}

model Admin {
  id               String     @id @default(uuid()) @db.Uuid
  username         String     @unique @db.VarChar(60)
  passwordHash     String     @db.VarChar(255)
  createdByAdminId String?    @db.Uuid
  createdByAdmin   Admin?     @relation("AdminCreatedAdmins", fields: [createdByAdminId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAdmins    Admin[]    @relation("AdminCreatedAdmins")
  employees        Employee[] @relation("AdminCreatedEmployees")
  tasks            Task[]     @relation("AdminCreatedTasks")
  bills            Bill[]     @relation("AdminCreatedBills")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @default(now()) @updatedAt

  @@index([createdByAdminId])
  @@index([createdAt])
}

model Employee {
  id               String       @id @default(uuid()) @db.Uuid
  username         String       @unique @db.VarChar(60)
  passwordHash     String       @db.VarChar(255)
  createdByAdminId String?      @db.Uuid
  createdByAdmin   Admin?       @relation("AdminCreatedEmployees", fields: [createdByAdminId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  assignedTasks    Task[]       @relation("EmployeeAssignedTasks")
  taskUpdates      TaskUpdate[] @relation("EmployeeTaskUpdates")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @default(now()) @updatedAt

  @@index([createdByAdminId])
  @@index([createdAt])
}

model Task {
  id                 String       @id @default(uuid()) @db.Uuid
  title              String       @db.VarChar(180)
  domain             String       @db.VarChar(120)
  clientName            String                @db.VarChar(160)
  clientEmail           String?               @db.VarChar(255)
  status                TaskStatus            @default(PENDING)
  isHighPriority        Boolean               @default(false)
  isBillable            Boolean               @default(false)
  billingApprovalStatus BillingApprovalStatus @default(NOT_REQUIRED)
  billAmount            Decimal?              @db.Decimal(10, 2)
  billingRemarks        String?               @db.Text
  assignedDate          DateTime              @db.Date
  dueDate            DateTime     @db.Date
  assignedEmployeeId String?      @db.Uuid
  createdByAdminId   String?      @db.Uuid
  assignedEmployee   Employee?    @relation("EmployeeAssignedTasks", fields: [assignedEmployeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdByAdmin     Admin?       @relation("AdminCreatedTasks", fields: [createdByAdminId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updates            TaskUpdate[] @relation("TaskUpdates")
  billItem           BillItem?    @relation("TaskBillItem")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @default(now()) @updatedAt

  @@index([assignedEmployeeId])
  @@index([createdByAdminId])
  @@index([status, dueDate])
  @@index([isHighPriority, dueDate])
  @@index([assignedDate])
  @@index([domain])
  @@index([clientName])
}

model TaskUpdate {
  id         String     @id @default(uuid()) @db.Uuid
  taskId     String     @db.Uuid
  employeeId String?    @db.Uuid
  status     TaskStatus
  remark     String?    @db.Text
  reason     String?    @db.Text
  task       Task       @relation("TaskUpdates", fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee   Employee?  @relation("EmployeeTaskUpdates", fields: [employeeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt  DateTime   @default(now())

  @@index([taskId])
  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
}

model BillingEntity {
  id                String         @id @default(uuid()) @db.Uuid
  name              String         @unique @db.VarChar(120)
  code              String         @unique @db.VarChar(20)
  invoicePrefix     String         @default("INV") @db.VarChar(20)
  email             String?        @db.VarChar(255)
  phone             String?        @db.VarChar(50)
  address           String?        @db.Text
  city              String?        @db.VarChar(100)
  state             String?        @db.VarChar(100)
  pincode           String?        @db.VarChar(20)
  country           String?        @db.VarChar(100)
  gstNumber         String?        @db.VarChar(50)
  panNumber         String?        @db.VarChar(50)
  bankName          String?        @db.VarChar(120)
  accountHolderName String?        @db.VarChar(160)
  bankAccountNumber String?        @db.VarChar(100)
  ifscCode          String?        @db.VarChar(50)
  branchName        String?        @db.VarChar(120)
  logoUrl           String?        @db.Text
  signatureUrl      String?        @db.Text
  declarationText   String?        @db.Text
  isActive          Boolean        @default(true)
  bills             Bill[]
  sequences         BillSequence[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @default(now()) @updatedAt
}

model BillSequence {
  id              String        @id @default(uuid()) @db.Uuid
  billingEntityId String        @db.Uuid
  financialYear   String        @db.VarChar(20)
  lastSequence    Int           @default(0)
  billingEntity   BillingEntity @relation(fields: [billingEntityId], references: [id], onDelete: Cascade)

  @@unique([billingEntityId, financialYear])
}

model Bill {
  id               String         @id @default(uuid()) @db.Uuid
  billNumber       String         @unique @db.VarChar(100)
  billingEntityId  String         @db.Uuid
  billingEntity    BillingEntity  @relation(fields: [billingEntityId], references: [id], onDelete: Restrict)
  sourceType       BillSourceType @default(TASK_BASED)
  clubbedIntoId    String?        @db.Uuid
  clubbedInto      Bill?          @relation("ClubbedBills", fields: [clubbedIntoId], references: [id], onDelete: SetNull)
  clubbedBills     Bill[]         @relation("ClubbedBills")
  billDate         DateTime       @default(now()) @db.Date
  clientName       String         @db.VarChar(160)
  clientEmail      String?        @db.VarChar(255)
  totalAmount      Decimal        @default(0) @db.Decimal(12, 2)
  status           BillStatus     @default(DRAFT)
  notes            String?        @db.Text
  clientDetails    Json?
  invoiceDetails   Json?
  taxDetails       Json?
  pdfUrl           String?        @db.Text
  generatedAt      DateTime?      @db.Timestamptz
  emailedAt        DateTime?      @db.Timestamptz
  createdByAdminId String?        @db.Uuid
  createdByAdmin   Admin?         @relation("AdminCreatedBills", fields: [createdByAdminId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items            BillItem[]     @relation("BillItems")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt

  @@index([billingEntityId])
  @@index([createdByAdminId])
  @@index([clientName])
  @@index([status])
  @@index([createdAt])
  @@index([clubbedIntoId])
}

model BillItem {
  id         String   @id @default(uuid()) @db.Uuid
  billId     String   @db.Uuid
  taskId     String?  @unique @db.Uuid
  taskTitle  String   @db.VarChar(180)
  taskDomain String   @db.VarChar(120)
  clientName String   @db.VarChar(160)
  amount     Decimal  @db.Decimal(10, 2)
  quantity   Int?     @default(1)
  rate       Decimal? @db.Decimal(10, 2)
  per        String?  @default("Nos") @db.VarChar(50)
  hsnSac     String?  @db.VarChar(50)
  remarks    String?  @db.Text
  
  bill       Bill     @relation("BillItems", fields: [billId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  task       Task?    @relation("TaskBillItem", fields: [taskId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  
  createdAt  DateTime @default(now())

  @@index([billId])
}
